# ---- Access gate (the code you paste into /activate) ----
ACCESS_CODE=let-me-in

# ---- Plan tier: solo | pro | agency (drives daily/monthly caps) ----
PLAN=solo

# ---- Email signature (also editable in-app at /settings) ----
SIG_NAME=
REPLY_EMAIL=
SIG_PHONE=
MAILING_ADDRESS=
# cal.com / Calendly URL — powers the "Book 15 min" CTA on preview pages
BOOKING_LINK=

# ---- Public base URL (used to build preview links in emails) ----
# Local dev: http://localhost:3000  |  Prod: https://yourdomain.com
APP_BASE_URL=http://localhost:3000

# ---- Anthropic (preview generation) ----
ANTHROPIC_API_KEY=
# Model used to generate redesign HTML
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Resend (sending + open/click tracking) ----
RESEND_API_KEY=
# Verified sending identity, e.g. "Eason <eason@yourdomain.com>"
RESEND_FROM=
# Where prospect replies should go
REPLY_TO=

# ---- Resend webhook signing secret (Settings -> Webhooks in Resend) ----
RESEND_WEBHOOK_SECRET=

# ---- The "Activate" offer shown on every preview page ----
# NOTE: escape the $ as \$ — dotenv treats $297 as a variable and expands it to empty.
# Or set it in-app at /app/settings (Activate offer → Price label), which avoids this.
ACTIVATE_PRICE=\$297/mo
# Where the Activate button sends the prospect (Stripe Payment Link, Cal.com, etc.)
# If empty, it falls back to mailto:REPLY_TO.
ACTIVATE_URL=

# ---- Google Places (lead scraping). Optional: CSV import works without it ----
GOOGLE_PLACES_API_KEY=

# ---- Email verification (Bouncer). Optional: skipped if empty ----
BOUNCER_API_KEY=

# ---- Safety: when true, emails are logged, not actually sent ----
DRY_RUN=true
